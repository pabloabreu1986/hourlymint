# ─────────────────────────────────────────────────────────────
# Supabase (capa gratuita). Copia este archivo a .env y rellena
# los valores de tu proyecto (Project Settings → API).
#
# Si dejas estas variables vacías o borras el .env, la app funciona
# igual con datos mock en localStorage (modo demo).
# ─────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY

# Bucket de Storage para las fotos (privado). Opcional; por defecto "fotos-obra".
VITE_SUPABASE_FOTOS_BUCKET=fotos-obra
